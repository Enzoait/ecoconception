# Obtain a connection string for your database from the Clusters tab on the MongoDB Atlas Dashboard.
# The connection string has the format `mongodb+srv://myDatabaseUser:D1fficultP%40ssw0rd@cluster0.example.mongodb.net/?retryWrites=true&w=majority`
MONGODB_URI=your-string-here

# Secret used to sign the session cookie. Change to a strong random value in production.
AUTH_SECRET=change-me-in-production

# k6 Cloud configuration for load tests.
K6_CLOUD_TOKEN=your-k6-cloud-token
K6_CLOUD_PROJECT_ID=8021352

# Public URL of the deployed application used by k6 scripts.
PUBLIC_APP_URL=https://your-app.vercel.app

# Toggle the optimised aggregate implementation.
# Set to "false" for the baseline CPU-heavy path, "true" for the optimised path.
CPU_OPTIMIZED=true

# In-memory cache TTL for /api/reports/aggregate (milliseconds).
AGGREGATE_CACHE_TTL_MS=30000

# Pyroscope / Grafana Cloud continuous profiling configuration.
# Get these from Grafana Cloud: Administration > Stack settings > Profiles.
PYROSCOPE_ENABLED=true
PYROSCOPE_APP_NAME=ecoconception-rust
PYROSCOPE_SERVER_URL=https://profiles-prod-eu-west-2.grafana.net
PYROSCOPE_USER=1714687
PYROSCOPE_API_TOKEN=your-pyroscope-token
